# ============================================================
# VANGUARD ERP/WMS — Variables de entorno
# ============================================================
# Copiá este archivo a `.env.local` y completá los valores reales.
# Nunca commitees `.env.local` al repo.
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# Crear proyecto en https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key-here
# SOLO servidor — nunca exponer al cliente. Permite bypass de RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key-here

# ── AUTH (NextAuth) ──────────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-min-32-chars

# ── IA OMNISCIENTE ───────────────────────────────────────────
# Backend Python de Vanguard IA (FastAPI). Default localhost.
# Sirve /predictions, /anomalies, /associations, /churn
# Repo: https://github.com/SVinas73/Vanguard-IA
NEXT_PUBLIC_AI_API_URL=http://localhost:8000
NEXT_PUBLIC_VANGUARD_IA_URL=http://localhost:8000

# ── POSTSALE MVP (análisis cualitativo LLM) ─────────────────
# Microservicio separado para análisis de email + tareas post-venta.
# Usado por el módulo "Clientes en Riesgo" para complementar el
# score numérico con razones cualitativas extraídas de Gmail.
# Repo: https://github.com/SVinas73/postsale-mvp
# Si lo dejás vacío, el módulo funciona solo con Vanguard-IA.
NEXT_PUBLIC_POSTSALE_URL=http://localhost:8001

# ── EXTRACCIÓN DE FACTURAS (Gemini multimodal) ───────────────
# Crear en https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-api-key

# ── SEGURIDAD ────────────────────────────────────────────────
# Auditoría con hash chain anti-tampering.
# Generar con: openssl rand -hex 32
AUDIT_HMAC_KEY=your-64-char-hex-key

# Encriptación de PII (cliente_email, telefono, etc).
# Generar con: openssl rand -hex 32
PII_ENCRYPTION_KEY=your-64-char-hex-key

# Token para que el cron pueda llamar al endpoint de dispatch de webhooks.
# Generar con: openssl rand -hex 24
WEBHOOKS_CRON_SECRET=your-cron-secret

# ── ENTORNO ──────────────────────────────────────────────────
# Next.js lo setea automáticamente, pero podés forzar 'production'
# para deshabilitar features de dev.
# NODE_ENV=development
